---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";

const developers = [
    { name: "nnpg", role: "Owner, Client Developer", image: "/nnpg.png" },
    {
        name: "doshibadev",
        role: "Web Developer, Client Developer",
        image: "/doshibadev.png",
    },
    { name: "femboy", role: "Client Developer", image: "/femboy.png" },
];

const staff = [
    { name: "Skyler", role: "Admin", image: "/skyler.png" },
    { name: "Ender", role: "Admin", image: "/ender.png" },
    { name: "aced", role: "Mod", image: "/aced.png" },
];

const contributors = [
    "A lot of them. Check on github/discord",
];

const openSourceProjects = [
    {
        name: "Meteor Client",
        url: "https://meteorclient.com",
        description: "The base modding framework Glazed is built on top of.",
    },
    {
        name: "Baritone",
        url: "https://github.com/cabaletta/baritone",
        description: "Pathfinding AI used for automated movement and mining.",
    },
    {
        name: "FabricMC",
        url: "https://fabricmc.net",
        description: "The mod loader and toolchain that makes it all possible.",
    },
    {
        name: "Claude AI",
        url: "https://claude.ai",
        description: "AI assistant used during development.",
    },
];

const techStack = ["Astro", "Tailwind CSS", "TypeScript", "Java", "Fabric API"];
---

<Layout title="Glazed - Credits">
    <div class="pt-32 pb-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-6xl font-heading font-bold mb-6">
                <span class="text-white">Credits & </span>
                <span class="text-brand-primary text-glow">Contributors</span>
            </h1>
            <p class="text-gray-400 text-xl max-w-2xl mx-auto">
                The talented team behind Glazed Client.
            </p>
        </div>

        <div class="mb-20">
            <h2
                class="text-3xl font-heading font-bold text-white mb-8 border-l-4 border-brand-primary pl-4"
            >
                Development Team
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
                {
                    developers.map((member) => (
                        <Card class="text-center group hover:-translate-y-2 transition-transform duration-300 flex flex-col items-center">
                            <div class="w-20 h-20 mb-4 mx-auto rounded-full bg-brand-surface-highlight border border-brand-primary/30 shadow-[0_0_15px_rgba(155,60,255,0.2)] overflow-hidden">
                                <img
                                    src={member.image}
                                    alt={member.name}
                                    class="w-full h-full object-cover rounded-full scale-110"
                                />
                            </div>
                            <h3 class="text-lg font-bold text-white mb-1">
                                {member.name}
                            </h3>
                            <p class="text-brand-primary font-mono text-xs uppercase tracking-wide">
                                {member.role}
                            </p>
                        </Card>
                    ))
                }
            </div>
        </div>

        <div class="mb-20">
            <h2
                class="text-3xl font-heading font-bold text-white mb-8 border-l-4 border-brand-accent pl-4"
            >
                Staff & Support
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
                {
                    staff.map((member) => (
                        <Card class="text-center group hover:-translate-y-2 transition-transform duration-300 flex flex-col items-center">
                            <div class="w-20 h-20 mb-4 mx-auto rounded-full bg-brand-surface-highlight border border-brand-accent/30 shadow-[0_0_15px_rgba(255,49,228,0.2)] overflow-hidden">
                                <img
                                    src={member.image}
                                    alt={member.name}
                                    class="w-full h-full object-cover rounded-full scale-110"
                                />
                            </div>
                            <h3 class="text-lg font-bold text-white mb-1">
                                {member.name}
                            </h3>
                            <p class="text-brand-accent font-mono text-xs uppercase tracking-wide">
                                {member.role}
                            </p>
                        </Card>
                    ))
                }
            </div>
        </div>

        <div class="mb-20">
            <h2
                class="text-3xl font-heading font-bold text-white mb-8 border-l-4 border-brand-primary pl-4"
            >
                Open Source
            </h2>
            <p class="text-gray-400 mb-8 max-w-2xl">
                Glazed wouldn't exist without these projects. Huge thanks to everyone who builds and maintains them.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {
                    openSourceProjects.map((project) => (
                        <Card class="flex flex-col gap-2">
                            <a
                                href={project.url}
                                target="_blank"
                                class="text-lg font-bold text-white hover:text-brand-primary transition-colors inline-flex items-center gap-2"
                            >
                                {project.name}
                                <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                            <p class="text-gray-400 text-sm">{project.description}</p>
                        </Card>
                    ))
                }
            </div>
        </div>

        <div class="mb-20">
            <h2
                class="text-3xl font-heading font-bold text-white mb-8 border-l-4 border-brand-accent pl-4"
            >
                GitHub Contributors
            </h2>
            <div class="flex flex-wrap gap-3">
                {
                    contributors.map((name) => (
                        <a
                            href={`https://github.com/${name}`}
                            target="_blank"
                            class="px-4 py-2 rounded-full bg-brand-surface border border-white/10 text-gray-300 text-sm font-mono hover:border-brand-primary/50 hover:text-white transition-all"
                        >
                            @{name}
                        </a>
                    ))
                }
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-brand-surface border border-white/5 rounded-xl p-8">
                <h3 class="text-xl font-heading font-bold text-white mb-6">
                    Built With
                </h3>
                <div class="flex flex-wrap gap-3">
                    {
                        techStack.map((tech) => (
                            <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-gray-300 text-sm font-mono">
                                {tech}
                            </span>
                        ))
                    }
                </div>
            </div>

            <div class="bg-brand-surface border border-white/5 rounded-xl p-8">
                <h3 class="text-xl font-heading font-bold text-white mb-4">
                    Disclaimer
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed mb-4">
                    Glazed Client is a third-party modification for Minecraft.
                    It is not affiliated with, endorsed by, or associated with
                    Mojang Studios or Microsoft Corporation.
                </p>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Usage of this software on multiplayer servers may violate
                    their terms of service. The developers of Glazed accept no
                    responsibility for any bans or penalties incurred.
                </p>
            </div>
        </div>
    </div>
</Layout>
